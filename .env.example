# DineDash Environment Variables — EXAMPLE FILE
# Copy this file to .env and fill in your actual values.
# NEVER commit the real .env file. It is already in .gitignore.

# ── SonarQube ─────────────────────────────────────────────────────────────────
SONAR_HOST_URL=http://localhost:9000
SONAR_TOKEN=squ_your_token_here

# ── DockerHub ──────────────────────────────────────────────────────────────────
DOCKERHUB_USERNAME=your-dockerhub-username
DOCKERHUB_IMAGE=your-dockerhub-username/dinedash

# ── AWS EC2 ────────────────────────────────────────────────────────────────────
EC2_HOST=your-ec2-public-ip-or-dns
EC2_USER=ubuntu
# EC2_KEY_PATH — path to your .pem file used by SSH (for local testing only)
EC2_KEY_PATH=/path/to/your-key.pem

# ── Email Notifications ────────────────────────────────────────────────────────
EMAIL_RECIPIENT=your-email@example.com

# ── App (optional, for future use) ────────────────────────────────────────────
REACT_APP_ENV=production
