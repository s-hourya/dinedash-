pipeline {
    agent any

    tools {
        jdk 'jdk17'
        nodejs 'node23'
    }

    environment {
        SCANNER_HOME        = tool 'sonar-scanner'
        DOCKERHUB_USERNAME  = 'ekansh69'
        IMAGE_NAME          = "${DOCKERHUB_USERNAME}/dinedash"
        IMAGE_TAG           = "latest"
        EC2_HOST            = '13.127.37.245'
        EC2_USER            = 'ec2-user'
        EC2_CREDENTIALS     = 'ec2-ssh-key'
        EMAIL_RECIPIENT     = 'ekanshlamba6226@gmail.com'
    }

    stages {

        // ─── Stage 1: Clean Workspace ──────────────────────────────────────────
        stage('Clean Workspace') {
            steps {
                cleanWs()
            }
        }

        // ─── Stage 2: Checkout Code ────────────────────────────────────────────
        stage('Git Checkout') {
            steps {
                git branch: 'main', url: 'https://github.com/s-hourya/dinedash-.git'
            }
        }

        // ─── Stage 3: SonarQube Analysis ──────────────────────────────────────
        /* 
        stage('SonarQube Analysis') {
            steps {
                withSonarQubeEnv('sonar-server') {
                    sh '''
                        $SCANNER_HOME/bin/sonar-scanner \
                            -Dsonar.projectName=dinedash \
                            -Dsonar.projectKey=dinedash \
                            -Dsonar.sources=src \
                            -Dsonar.javascript.lcov.reportPaths=coverage/lcov.info
                    '''
                }
            }
        }

        stage('Quality Gate') {
            steps {
                script {
                    waitForQualityGate abortPipeline: true, credentialsId: 'Sonar-token'
                }
            }
        }
        */

        // ─── Stage 5: Install Dependencies ────────────────────────────────────
        stage('Install NPM Dependencies') {
            steps {
                sh 'npm ci'
            }
        }

        // ─── Stage 6: OWASP Dependency Check ──────────────────────────────────
        stage('OWASP Dependency Check') {
            steps {
                dependencyCheck(
                    additionalArguments: '--scan ./ --disableYarnAudit --disableNodeAudit -n --format HTML --format XML',
                    odcInstallation: 'DP-Check'
                )
                dependencyCheckPublisher pattern: '**/dependency-check-report.xml'
            }
        }

        // ─── Stage 7: Trivy File System Scan ──────────────────────────────────
        stage('Trivy File System Scan') {
            steps {
                sh 'trivy fs --format table -o trivy-fs.txt .'
            }
        }

        // ─── Stage 8: Docker Build ─────────────────────────────────────────────
        stage('Docker Build') {
            steps {
                sh "docker build -t ${IMAGE_NAME}:${IMAGE_TAG} ."
            }
        }

        // ─── Stage 9: Trivy Image Scan ─────────────────────────────────────────
        stage('Trivy Image Scan') {
            steps {
                sh "trivy image --format table -o trivy-image.txt ${IMAGE_NAME}:${IMAGE_TAG}"
            }
        }

        // ─── Stage 10: Push to DockerHub ──────────────────────────────────────
        stage('Push to DockerHub') {
            steps {
                script {
                    withDockerRegistry(credentialsId: 'docker', toolName: 'docker') {
                        sh "docker push ${IMAGE_NAME}:${IMAGE_TAG}"
                    }
                }
            }
        }

        // ─── Stage 11: Deploy to AWS EC2 ──────────────────────────────────────
        stage('Deploy to EC2') {
            steps {
                sshagent(credentials: [EC2_CREDENTIALS]) {
                    sh """
                        ssh -o StrictHostKeyChecking=no ${EC2_USER}@${EC2_HOST} '
                            docker stop dinedash 2>/dev/null || true
                            docker rm   dinedash 2>/dev/null || true
                            docker pull ${IMAGE_NAME}:${IMAGE_TAG}
                            docker run -d \
                                --name dinedash \
                                --restart unless-stopped \
                                -p 80:80 \
                                ${IMAGE_NAME}:${IMAGE_TAG}
                        '
                    """
                }
            }
        }

        // ─── Stage 12 (Optional): Terminate EC2 ───────────────────────────────
        // Uncomment below to terminate EC2 after deployment for cost optimization.
        // Requires AWS CLI configured on Jenkins agent with proper IAM permissions.
        //
        // stage('Terminate EC2') {
        //     steps {
        //         sh """
        //             INSTANCE_ID=$(aws ec2 describe-instances \
        //                 --filters "Name=ip-address,Values=${EC2_HOST}" \
        //                 --query "Reservations[0].Instances[0].InstanceId" \
        //                 --output text)
        //             aws ec2 terminate-instances --instance-ids $INSTANCE_ID
        //         """
        //     }
        // }

    }

    post {
        always {
            emailext(
                attachLog: true,
                subject: "DineDash Build #${env.BUILD_NUMBER} — ${currentBuild.result}",
                body: """
                    <html>
                    <body style="font-family: Arial, sans-serif; padding: 20px;">
                        <h2 style="color: #e23744;">DineDash CI/CD Pipeline Report</h2>
                        <table style="border-collapse: collapse; width: 100%;">
                            <tr style="background-color: #FFA07A;">
                                <td style="padding: 10px; color: white; font-weight: bold;">Project</td>
                                <td style="padding: 10px;">${env.JOB_NAME}</td>
                            </tr>
                            <tr style="background-color: #90EE90;">
                                <td style="padding: 10px; color: white; font-weight: bold;">Build Number</td>
                                <td style="padding: 10px;">${env.BUILD_NUMBER}</td>
                            </tr>
                            <tr style="background-color: #87CEEB;">
                                <td style="padding: 10px; color: white; font-weight: bold;">Status</td>
                                <td style="padding: 10px;">${currentBuild.result}</td>
                            </tr>
                            <tr>
                                <td style="padding: 10px; font-weight: bold;">Build URL</td>
                                <td style="padding: 10px;"><a href="${env.BUILD_URL}">${env.BUILD_URL}</a></td>
                            </tr>
                        </table>
                        <p style="color: #888; font-size: 12px; margin-top: 20px;">
                            Trivy scan report and full build logs are attached.
                        </p>
                    </body>
                    </html>
                """,
                to: EMAIL_RECIPIENT,
                mimeType: 'text/html',
                attachmentsPattern: 'trivy-fs.txt,trivy-image.txt'
            )
        }
        success {
            echo "✅ DineDash deployed successfully! Access at: http://${EC2_HOST}"
        }
        failure {
            echo "❌ Pipeline failed. Check logs and scan reports."
        }
    }
}
